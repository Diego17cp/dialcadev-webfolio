---
import { Icon } from "astro-icon/components";

const experiences = [
    {
        title: "Frontend Developer",
        company: "TecnoSolutions",
        period: "August 2025 - January 2026",
        description: "Developed and maintained user interfaces for web applications using React, Astro, TypeScript, and TailwindCSS. Collaborated with designers and back-end developers to create responsive and user-friendly web experiences.",
        technologies: ["React", "Astro", "TypeScript", "TailwindCSS"]
    },
    {
        title: "FullStack Developer Junior",
        company: "Municipalidad Distrital de JLO",
        period: "August 2025 - July 2026",
        description: "Worked on developing and maintaining full-stack web applications using React, TypeScript, Express, and PostgreSQL. Contributed to front-end and back-end development, ensuring responsive design and optimal performance.",
        technologies: ["React", "TypeScript", "Express", "PostgreSQL", "Astro", "TailwindCSS", "Node.js", "CodeIgniter", "Flutter", "Dart"]
    },
    {
        title: "FullStack Developer Trainee",
        company: "Municipalidad Distrital de JLO",
        period: "February 2025 - July 2025",
        description: "Developed and maintained web applications using CodeIgniter framework.",
        technologies: ["CodeIgniter", "PHP", "HTML", "CSS", "JavaScript"]
    }
];
---

<section id="experience" class="my-20 md:my-28">
    <div class="flex items-center gap-3 mb-12 ml-1 md:ml-4">
        <Icon name="tabler:briefcase" class="w-8 h-8 text-blue-400" />
        <h2 class="text-3xl md:text-4xl font-bold text-white">
            Experience
        </h2>
    </div>
    <div class="relative">
        <div class="absolute left-4 md:left-8 top-0 bottom-0 w-0.5 bg-white/20"></div>
        <div class="space-y-8 md:space-y-12">
            {experiences.map((exp) => (
                <div class="relative pl-12 md:pl-20">
                    <div class="absolute left-2 md:left-6 top-1 w-4 h-4 rounded-full bg-blue-400 border-4 border-black"></div>
                    <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all duration-300">
                        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-3">
                            <div>
                                <h3 class="text-xl md:text-2xl font-semibold text-white">
                                    {exp.title}
                                </h3>
                                <p class="text-blue-400 font-medium">
                                    {exp.company}
                                </p>
                            </div>
                            <span class="text-sm text-white/60 font-medium whitespace-nowrap">
                                {exp.period}
                            </span>
                        </div>
                        <p class="text-white/80 mb-4 leading-relaxed">
                            {exp.description}
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {exp.technologies.map(tech => (
                                <span class="px-3 py-1 text-xs font-medium bg-blue-500/20 text-blue-300 rounded-full border border-blue-500/30">
                                    {tech}
                                </span>
                            ))}
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>