---
const { project } = Astro.props;
const slug = project.slug;
const {
	title,
	description,
	image,
	technologies,
	github,
	demo,
	npm,
	download,
	featured = false,
} = project.data;

import { Icon } from "astro-icon/components";

interface Technology {
	name: string;
	icon: string;
	color: string;
}
---

<article
	class={`h-full flex flex-col group relative overflow-hidden rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10
	hover:bg-white/10 transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-500/20
	${featured ? "md:col-span-2" : "col-span-1"}`}
>
	<a href={`/projects/${slug}`} class="block">
		<div class="relative aspect-video w-full overflow-hidden">
			<img
				src={image}
				alt={title}
				transition:name={`project-${slug}`}
				class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
			/>
			<div
				class="absolute inset-0 bg-linear-to-t from-black/80 to-transparent"
			>
			</div>
		</div>
	</a>
	<div class="p-6 flex-1 flex flex-col">
		<div class="flex items-start justify-between gap-4 mb-3">
			<a href={`/projects/${slug}`} class="flex-1">
				<h3 class="text-xl md:text-2xl font-bold text-white hover:text-blue-400 transition-colors">
					{title}
				</h3>
			</a>
			<div class="flex gap-2 shrink-0">
				{
					github && (
						<a
							href={github}
							target="_blank"
							rel="noopener noreferrer"
							class="project-action-btn bg-black/10 border-white/20 hover:bg-black"
							aria-label="View on GitHub"
						>
							<Icon name="tabler:brand-github" class="w-5 h-5" />
						</a>
					)
				}
				{
					demo && (
						<a
							href={demo}
							target="_blank"
							rel="noopener noreferrer"
							class="project-action-btn bg-blue-500/20 border-blue-500/30 hover:bg-blue-500"
							aria-label="View live demo"
						>
							<Icon name="tabler:external-link" class="w-5 h-5" />
						</a>
					)
				}
				{
					npm && (
						<a
							href={npm}
							target="_blank"
							rel="noopener noreferrer"
							class="project-action-btn bg-red-400/20 border-red-500/30 hover:bg-red-400"
							aria-label="View on NPM"
						>
							<Icon name="tabler:brand-npm" class="w-5 h-5" />
						</a>
					)
				}
				{
					download && (
						<a
							href={download}
							target="_blank"
							rel="noopener noreferrer"
							class="project-action-btn bg-purple-500/20 border-purple-500/30 hover:bg-purple-500"
							aria-label="Download"
						>
							<Icon name="tabler:download" class="w-5 h-5" />
						</a>
					)
				}
			</div>
		</div>
		<a href={`/projects/${slug}`} class="block">
			<p
				class="text-white/80 mb-4 leading-relaxed hover:text-white transition-colors"
			>
				{description}
			</p>
		</a>
		<div class="flex flex-wrap gap-2 mt-auto">
			{
				technologies.map((tech: Technology) => (
					<span
						class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-white rounded-lg border border-white/10"
						style={`background-color: ${tech.color}50`}
					>
						<Icon name={tech.icon} class="w-4 h-4 text-white" />
						{tech.name}
					</span>
				))
			}
		</div>
	</div>
</article>
