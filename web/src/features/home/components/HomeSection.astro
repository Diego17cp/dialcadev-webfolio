---
import { Icon } from "astro-icon/components";

const { id, icon, title, headerClass } = Astro.props;
---
<section id={id} class="my-20 md:my-28 pt-5">
    <div class={`flex items-center gap-3 mb-12 ${headerClass}`}>
        <Icon name={icon} class="w-8 h-8 text-blue-400" />
        <h2 class="text-3xl md:text-4xl font-bold text-white">
            {title}
        </h2>
    </div>
    <slot />
</section>